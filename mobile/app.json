{
  "expo": {
    "name": "Apartment Bill Tracker",
    "slug": "apartment-bill-tracker",
    "icon": "./src/assets/icon.png",
    "version": "1.2.2",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "aptbilltracker",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.apartmentbilltracker.ios",
      "scheme": "aptbilltracker",
      "userInterfaceStyle": "automatic"
    },
    "android": {
      "package": "com.apartmentbilltracker",
      "scheme": "aptbilltracker",
      "userInterfaceStyle": "automatic",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.googleusercontent.apps.280450131002-iv8nv3hnottf109ft2ruogaq4daqjpbh"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [{ "scheme": "fb1296319515642952" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./src/assets/icon.png",
          "colors": ["#b38604"],
          "modes": ["production"]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "72a4be98-f7c2-4e5c-8d5a-5b7a8fd1a75c"
      }
    },
    "owner": "apartmentbilltracker"
  }
}
